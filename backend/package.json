    "bull": "^1.1.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "neo4j-driver": "^5.15.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
