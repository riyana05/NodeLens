{
  "name": "nodelens-backend",
  "version": "1.0.0",
  "description": "NodeLens Analytics Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seedNeo4j.js",
