# MongoDB Atlas
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/socialgraph

# Neo4j AuraDB
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-password

# Redis (Upstash)
REDIS_URL=redis://default:your-password@xxxx.upstash.io:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# C++ Engine binary path (relative to backend/)
CPP_ENGINE_PATH=../graph-engine/build/graph-engine
